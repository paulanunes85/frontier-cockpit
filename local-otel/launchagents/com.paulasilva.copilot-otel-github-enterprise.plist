    <integer>30</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>$HOME/frontier-cockpit/local-otel/launchagent-github-enterprise.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/frontier-cockpit/local-otel/launchagent-github-enterprise.err</string>
